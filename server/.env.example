# ---- AI (required for the assistant + translator) ----
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Database (required for real accounts) ----
# Neon: create a project at https://neon.tech, then copy the connection string.
# Leave unset to run in demo mode (accounts stored in the browser instead).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# Secret used to sign login tokens. Use a long random string in production, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ---- Optional ----
# PORT=4000
# Comma-separated list of allowed frontend origins in production:
# CORS_ORIGIN=https://your-app.vercel.app
# Live fixtures feed (see matches.js):
# LIVE_FOOTBALL_API_URL=
# LIVE_FOOTBALL_API_KEY=
